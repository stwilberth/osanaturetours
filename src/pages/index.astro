---
import Layout from '../layouts/PageLayout.astro';
import MainSlider from '~/components/MainSlider.astro';
import SharingButtons from '~/components/SharingButtons.astro';
import tours from '~/data/tours';
---

<Layout title="Osanature Tours | Eco Adventures in Osa Peninsula">
  <SharingButtons />
  <main class="min-h-screen bg-gradient-to-b from-yellow-400 to-yellow-600">
    <MainSlider tours={tours} />
    <section class="py-16 container mx-auto px-4">
      <h1 class="text-3xl md:text-4xl font-bold text-white text-center mb-12">
        Osa Nature Tours
      </h1>
      <p class="text-lg md:text-xl text-center max-w-2xl mx-auto mb-8 text-white">
        Osa Nature Tours offers unique and authentic experiences, where each visitor embarks on an unforgettable adventure, exploring the majesty of nature. Accompanied by a certified local guide, you will discover breathtaking landscapes, exceptional wildlife, and the pure essence of the region through carefully designed excursions that connect you with the environment.
      </p>
    </section>

  </main>
</Layout>
