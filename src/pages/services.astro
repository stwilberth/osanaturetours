---
import Layout from '~/layouts/PageLayout.astro';
---

<Layout metadata={{ title: 'Our Services' }}>
  <main class="min-h-screen bg-gradient-to-b from-green-50 to-green-100 p-8">
    <h1 class="text-4xl font-bold text-center text-green-800 mb-6 mt-16">Our Tour Services</h1>
    
    <section class="container mx-auto">
      <p class="text-lg text-center mb-4">
        Explore the beauty of the Osa Peninsula with our expert-guided tours. We offer a variety of services to ensure you have an unforgettable experience.
      </p>
      
      <ul class="list-disc list-inside space-y-2">
        <li>Guided Nature Tours</li>
        <li>Cultural Experiences</li>
        <li>Customizable Tour Packages</li>
        <li>Transportation Services</li>
        <li>Wildlife Watching Tours</li>
      </ul>
      
      <h2 class="text-2xl font-bold text-green-700 mt-6">Why Choose Us?</h2>
      <p class="text-lg mb-4">
        Our tours are led by local experts who are passionate about sharing the natural beauty and culture of the Osa Peninsula. We prioritize eco-friendly practices and personalized service to make your trip memorable.
      </p>
      
      <div class="text-center mt-6">
        <a href="/contact" class="btn bg-green-600 text-white">Contact Us to Book Your Tour!</a>
      </div>
    </section>
  </main>
</Layout>
