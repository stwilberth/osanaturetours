            </a>
            <a href={facebook} target="_blank" rel="noopener noreferrer" class="bg-blue-600 text-white p-3 rounded-full hover:bg-blue-700 transition">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="currentColor">
                <path d="M22 12.073C22 6.505 17.523 2 12 2S2 6.505 2 12.073c0 5.047 3.656 9.228 8.438 9.928V15.34H7.897v-3.267h2.541V9.847c0-2.506 1.49-3.893 3.776-3.893 1.096 0 2.238.195 2.238.195v2.512h-1.26c-1.24 0-1.627.774-1.627 1.568v1.844h2.773l-.444 3.267h-2.329v6.662C18.344 21.3 22 17.12 22 12.073z"/>
              </svg>
            </a>

            <a href={instagram} target="_blank" rel="noopener noreferrer" class="bg-pink-600 text-white p-3 rounded-full hover:bg-pink-700 transition">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="currentColor">
                <path d="M7.75 2A5.75 5.75 0 002 7.75v8.5A5.75 5.75 0 007.75 22h8.5A5.75 5.75 0 0022 16.25v-8.5A5.75 5.75 0 0016.25 2h-8.5zM12 6.75a5.25 5.25 0 110 10.5 5.25 5.25 0 010-10.5zm0 1.5a3.75 3.75 0 100 7.5 3.75 3.75 0 000-7.5zM17.5 6.5a1.25 1.25 0 110 2.5 1.25 1.25 0 010-2.5z"/>
              </svg>
            </a>

            <a href={youtube} target="_blank" rel="noopener noreferrer" class="bg-red-600 text-white p-3 rounded-full hover:bg-red-700 transition">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="currentColor">
                <path d="M23.498 6.186a2.876 2.876 0 00-2.021-2.046C19.055 3.5 12 3.5 12 3.5s-7.055 0-9.478.64A2.876 2.876 0 00.5 6.186C0 8.484 0 12 0 12s0 3.516.5 5.814a2.876 2.876 0 002.022 2.046C4.945 20.5 12 20.5 12 20.5s7.055 0 9.478-.64a2.876 2.876 0 002.021-2.046C24 15.516 24 12 24 12s0-3.516-.502-5.814zM9.75 15.375V8.625L15.75 12l-6 3.375z"/>
              </svg>
            </a>

            <!-- tiktok -->
            <a href="https://www.tiktok.com/@osanaturetours" target="_blank" rel="noopener noreferrer" class="bg-black text-white p-3 rounded-full hover:bg-gray-800 transition">
              <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><g id="SVGRepo_bgCarrier" stroke-width="0"></g><g id="SVGRepo_tracerCarrier" stroke-linecap="round" stroke-linejoin="round"></g><g id="SVGRepo_iconCarrier"> <path d="M16.8218 5.1344C16.0887 4.29394 15.648 3.19805 15.648 2H14.7293C14.9659 3.3095 15.7454 4.43326 16.8218 5.1344Z" fill="#ffffff"></path> <path d="M8.3218 11.9048C6.73038 11.9048 5.43591 13.2004 5.43591 14.7931C5.43591 15.903 6.06691 16.8688 6.98556 17.3517C6.64223 16.8781 6.43808 16.2977 6.43808 15.6661C6.43808 14.0734 7.73255 12.7778 9.324 12.7778C9.62093 12.7778 9.90856 12.8288 10.1777 12.9124V9.40192C9.89927 9.36473 9.61628 9.34149 9.324 9.34149C9.27294 9.34149 9.22654 9.34614 9.1755 9.34614V12.0394C8.90176 11.9558 8.61873 11.9048 8.3218 11.9048Z" fill="#ffffff"></path> <path d="M19.4245 6.67608V9.34614C17.6429 9.34614 15.9912 8.77501 14.6456 7.80911V14.7977C14.6456 18.2851 11.8108 21.127 8.32172 21.127C6.97621 21.127 5.7235 20.6998 4.69812 19.98C5.8534 21.2198 7.50049 22 9.32392 22C12.8083 22 15.6478 19.1627 15.6478 15.6707V8.68211C16.9933 9.64801 18.645 10.2191 20.4267 10.2191V6.78293C20.0787 6.78293 19.7446 6.74574 19.4245 6.67608Z" fill="#ffffff"></path> <path d="M14.6456 14.7977V7.80911C15.9912 8.77501 17.6429 9.34614 19.4245 9.34614V6.67608C18.3945 6.45788 17.4899 5.90063 16.8218 5.1344C15.7454 4.43326 14.9704 3.3095 14.7245 2H12.2098L12.2051 15.7775C12.1495 17.3192 10.8782 18.5591 9.32393 18.5591C8.35884 18.5591 7.50977 18.0808 6.98085 17.3564C6.06219 16.8688 5.4312 15.9076 5.4312 14.7977C5.4312 13.205 6.72567 11.9094 8.31708 11.9094C8.61402 11.9094 8.90168 11.9605 9.17079 12.0441V9.35079C5.75598 9.42509 3 12.2298 3 15.6707C3 17.3331 3.64492 18.847 4.69812 19.98C5.7235 20.6998 6.97621 21.127 8.32172 21.127C11.8061 21.127 14.6456 18.2851 14.6456 14.7977Z" fill="#ffffff"></path> </g></svg>
            </a>

          </div>

        </div>
      </div>
    </div>
  </main>
</Layout>
