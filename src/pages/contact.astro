---
import Layout from '../layouts/PageLayout.astro';
const { phoneNumber = "50687933753", email = "josecorcovado@gmail.com" } = Astro.props;

const metadata = {
  title: 'Contact Us | Osanature Tours',
};
---

<Layout metadata={metadata}>
  <main class="pt-8 pb-32 bg-gradient-to-b from-green-50 to-green-100">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <h1 class="text-4xl md:text-4xl font-bold text-green-800 text-center mb-8">Contact Us</h1>
        
        <form
        name="contact"
        method="POST"
        data-netlify="true"
        class="bg-white rounded-xl shadow-lg pb-5 px-5 space-y-1"
        >
        <div class="flex justify-center">
          <a
            href={`https://wa.me/${phoneNumber}`}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 text-green-800 hover:bg-green-50 px-4 py-2 rounded-lg transition-colors"
            aria-label="Contact via WhatsApp"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" viewBox="0 0 24 24" fill="currentColor">
              <path
                d="M12.031 6.172c-3.181 0-5.767 2.586-5.768 5.766-.001 1.298.38 2.27 1.019 3.287l-.582 2.128 2.182-.573c.978.58 1.911.928 3.145.929 3.178 0 5.767-2.587 5.768-5.766.001-3.187-2.575-5.77-5.764-5.771zm3.392 8.244c-.144.405-.837.774-1.17.824-.299.045-.677.063-1.092-.069-.252-.08-.575-.187-.988-.365-1.739-.751-2.874-2.502-2.961-2.617-.087-.116-.708-.94-.708-1.793s.448-1.273.607-1.446c.159-.173.346-.217.462-.217l.332.006c.106.005.249-.04.39.298.144.347.491 1.2.534 1.287.043.087.072.188.014.304-.058.116-.087.188-.173.289l-.26.304c-.087.086-.177.18-.076.354.101.174.449.741.964 1.201.662.591 1.221.774 1.394.86s.274.072.376-.043c.101-.116.433-.506.549-.68.116-.173.231-.145.39-.087s1.011.477 1.184.564.289.13.332.202c.045.072.045.419-.1.824z"
              ></path>
            </svg>
          </a>
          <a
            href={`tel:+${phoneNumber}`}
            class="flex items-center gap-2 text-green-800 hover:bg-green-50 px-4 py-2 rounded-lg transition-colors"
            aria-label="Call us"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
              ></path>
            </svg>
          </a>
          <a
            href={`mailto:${email}`}
            class="flex items-center gap-2 text-green-800 hover:bg-green-50 px-4 py-2 rounded-lg transition-colors"
            aria-label="Email us"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              ></path>
            </svg>
          </a>
          
        </div>
          <input type="hidden" name="form-name" value="contact" />

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
            <div>
              <input
                type="text"
                name="name"
                id="name"
                placeholder="Name"
                required
                class="w-full px-4 p-1 rounded-lg border border-gray-300 focus:ring-2 focus:ring-green-500 focus:border-transparent transition duration-200"
              />
            </div>
            <div>
              <input
                type="email"
                name="email"
                id="email"
                placeholder="Email"
                required
                class="w-full px-4 py-1 rounded-lg border border-gray-300 focus:ring-2 focus:ring-green-500 focus:border-transparent transition duration-200"
              />
            </div>
          </div>

          <div>
            <select
              name="tour"
              id="tour"
              class="w-full px-4 py-1 mt-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-green-500 focus:border-transparent transition duration-200"
            >
              <option value="">Select a tour (optional)</option>
              <option value="gold-tour">Gold Tour</option>
              <option value="night-walk">Night Walk</option>
              <option value="salto-hike">The Salto Hike</option>
              <option value="rainforest-hike">Rainforest Hike</option>
              <option value="bird-watching">Bird Watching Tour</option>
              <option value="corcovado">Corcovado One Day Tour</option>
              <option value="one-day-rainforest">One Day Rainforest Hike</option>
            </select>
          </div>

          <div>
            <textarea
              name="message"
              id="message"
              required
              rows="5"
              placeholder="Your message here..."
              class="w-full px-4 py-2 mt-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-green-500 focus:border-transparent transition duration-200"
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full bg-green-800 text-white py-3 px-6 rounded-lg hover:bg-green-700 transition-colors duration-300 font-medium"
          >
            Send Message
          </button>
        </form>
      </div>
    </div>
  </main>
</Layout>
