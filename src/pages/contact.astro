---
import Layout from '../layouts/PageLayout.astro';
const { phoneNumber = "50687933753", email = "josecorcovado@gmail.com", facebook = "https://www.facebook.com/osanaturetours", instagram = "https://www.instagram.com/osanaturetours", youtube = "https://www.youtube.com/@osanaturetours" } = Astro.props;

const metadata = {
  title: 'Contact Us | Osanature Tours',
};
---

<Layout metadata={metadata}>
  <main class="pt-8 pb-32 bg-gradient-to-b from-green-50 to-green-100">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-4xl md:text-4xl font-bold text-green-800 mb-8">Contact Us</h1>

        <div class="space-y-4">
          <div>
            <p class="text-lg text-green-800 font-semibold">Phone:</p>
            <a href={`tel:+${phoneNumber}`} class="text-green-600 hover:underline text-lg">
              +{phoneNumber}
            </a>
          </div>

          <div class="pb-5">
            <p class="text-lg text-green-800 font-semibold">WhatsApp:</p>
            <a href={`https://wa.me/${phoneNumber}`} target="_blank" rel="noopener noreferrer" class="text-green-600 hover:underline text-lg">
              Chat on WhatsApp
            </a>
          </div>

          
          <div class="flex justify-center gap-2">
            <!-- whatsapp button -->
            <a href={`https://wa.me/${phoneNumber}`} target="_blank" rel="noopener noreferrer" class="bg-green-600 text-white p-3 rounded-full hover:bg-green-700 transition">
