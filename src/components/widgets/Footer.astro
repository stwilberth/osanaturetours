---
import { Icon } from 'astro-icon/components';
import { SITE } from 'astrowind:config';
import { getHomePermalink } from '~/utils/permalinks';

interface Link {
  text?: string;
  href?: string;
  ariaLabel?: string;
  icon?: string;
}

interface Links {
  title?: string;
  links: Array<Link>;
}

export interface Props {
  links: Array<Links>;
  secondaryLinks: Array<Link>;
  socialLinks: Array<Link>;
  footNote?: string;
  theme?: string;
}

const { socialLinks = [], secondaryLinks = [], links = [], footNote = '', theme = 'green' } = Astro.props;
---

<footer class:list={[{ dark: theme === 'dark' }, 'relative border-t border-green-200 not-prose bg-green-50']}>
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 text-gray-700">
    <div class="grid grid-cols-12 gap-4 gap-y-8 sm:gap-8 py-8 md:py-12">
      <div class="col-span-12 lg:col-span-4">
        <div class="mb-2">
          <a class="inline-block font-bold text-xl text-green-800" href={getHomePermalink()}>{SITE?.name}</a>
        </div>
        <div class="text-sm text-gray-600 flex gap-1">
          {
            secondaryLinks.map(({ text, href }, index) => (
              <>
                {index !== 0 ? ' · ' : ''}
                <a
                  class="text-gray-600 hover:text-green-700 hover:underline transition duration-150 ease-in-out"
                  href={href}
                  set:html={text}
                />
              </>
            ))
          }
        </div>
      </div>

      {/* Contact Information Section */}
      <div class="col-span-12 md:col-span-8 lg:col-span-8">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="text-center">
            <div class="bg-white rounded-full w-12 h-12 flex items-center justify-center mx-auto mb-4 shadow-md">
              <Icon name="tabler:phone" class="w-6 h-6 text-green-800" />
            </div>
            <h3 class="text-lg font-semibold text-green-800 mb-2">Phone</h3>
            <p class="text-gray-600">
              <a href="tel:+5068793753" class="hover:text-green-700">+506 8793 3753</a>
            </p>
          </div>

          <div class="text-center">
            <div class="bg-white rounded-full w-12 h-12 flex items-center justify-center mx-auto mb-4 shadow-md">
              <Icon name="tabler:mail" class="w-6 h-6 text-green-800" />
            </div>
            <h3 class="text-lg font-semibold text-green-800 mb-2">Email</h3>
            <p class="text-gray-600">
              <a href="mailto:josecorcovado@gmail.com" class="hover:text-green-700">josecorcovado@gmail.com</a>
            </p>
          </div>

          <div class="text-center">
            <div class="bg-white rounded-full w-12 h-12 flex items-center justify-center mx-auto mb-4 shadow-md">
              <Icon name="tabler:map-pin" class="w-6 h-6 text-green-800" />
            </div>
            <h3 class="text-lg font-semibold text-green-800 mb-2">Location</h3>
            <p class="text-gray-600">
              Dos Brazos, Osa Peninsula<br />
              Costa Rica
            </p>
          </div>
        </div>
      </div>
    </div>

    <div class="md:flex md:items-center md:justify-between py-6 md:py-8 border-t border-green-200">
      {
        socialLinks?.length ? (
          <ul class="flex mb-4 md:order-1 -ml-2 md:ml-4 md:mb-0">
            {socialLinks.map(({ ariaLabel, href, text, icon }) => (
              <li>
                <a
                  class="text-gray-500 hover:bg-green-100 focus:outline-none focus:ring-4 focus:ring-green-200 rounded-lg text-sm p-2.5 inline-flex items-center"
                  aria-label={ariaLabel}
                  href={href}
                >
                  {icon && <Icon name={icon} class="w-5 h-5" />}
                  <Fragment set:html={text} />
                </a>
              </li>
            ))}
          </ul>
        ) : (
          ''
        )
      }

      <div class="text-sm text-gray-600">
        <Fragment set:html={footNote} />
      </div>
    </div>
  </div>
</footer>
