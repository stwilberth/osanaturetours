---
const { phoneNumber = "50687933753", email = "josecorcovado@gmail.com" } = Astro.props;
---

<div class="fixed bottom-6 right-6 flex flex-col gap-3 items-end z-50">
  <div class="contact-menu bg-white/90 backdrop-blur rounded-lg shadow-lg p-2 transform scale-0 opacity-0 transition-all duration-300">
    <div class="flex flex-col gap-2">
      <a
        href={`https://wa.me/${phoneNumber}`}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 text-green-800 hover:bg-green-50 px-4 py-2 rounded-lg transition-colors"
        aria-label="Contact via WhatsApp"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12.031 6.172c-3.181 0-5.767 2.586-5.768 5.766-.001 1.298.38 2.27 1.019 3.287l-.582 2.128 2.182-.573c.978.58 1.911.928 3.145.929 3.178 0 5.767-2.587 5.768-5.766.001-3.187-2.575-5.77-5.764-5.771zm3.392 8.244c-.144.405-.837.774-1.17.824-.299.045-.677.063-1.092-.069-.252-.08-.575-.187-.988-.365-1.739-.751-2.874-2.502-2.961-2.617-.087-.116-.708-.94-.708-1.793s.448-1.273.607-1.446c.159-.173.346-.217.462-.217l.332.006c.106.005.249-.04.39.298.144.347.491 1.2.534 1.287.043.087.072.188.014.304-.058.116-.087.188-.173.289l-.26.304c-.087.086-.177.18-.076.354.101.174.449.741.964 1.201.662.591 1.221.774 1.394.86s.274.072.376-.043c.101-.116.433-.506.549-.68.116-.173.231-.145.39-.087s1.011.477 1.184.564.289.13.332.202c.045.072.045.419-.1.824z"/>
        </svg>
        WhatsApp
      </a>
      <a
        href={`tel:+${phoneNumber}`}
        class="flex items-center gap-2 text-green-800 hover:bg-green-50 px-4 py-2 rounded-lg transition-colors"
        aria-label="Call us"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        Call
      </a>
      <a
        href={`mailto:${email}`}
        class="flex items-center gap-2 text-green-800 hover:bg-green-50 px-4 py-2 rounded-lg transition-colors"
        aria-label="Email us"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
        Email
      </a>
      <a
        href="/contact"
        class="flex items-center gap-2 text-green-800 hover:bg-green-50 px-4 py-2 rounded-lg transition-colors"
        aria-label="Contact form"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z" />
        </svg>
        Contact Form
      </a>
    </div>
  </div>
  <button
    id="contact-toggle"
    class="bg-green-800 text-white p-3 rounded-full shadow-lg hover:bg-green-700 transition-colors duration-300"
    aria-label="Toggle contact menu"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
    </svg>
  </button>
</div>

<script>
  document.addEventListener('astro:page-load', () => {
    const toggle = document.getElementById('contact-toggle');
    const menu = document.querySelector('.contact-menu');
    let isOpen = false;

    toggle?.addEventListener('click', () => {
      isOpen = !isOpen;
      if (isOpen) {
        menu?.classList.remove('scale-0', 'opacity-0');
        menu?.classList.add('scale-100', 'opacity-100');
      } else {
        menu?.classList.remove('scale-100', 'opacity-100');
        menu?.classList.add('scale-0', 'opacity-0');
      }
    });
  });
</script>
